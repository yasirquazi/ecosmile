---
interface CTABlock {
  audience: string;
  copy: string;
  cta: { label: string; href: string };
  riskNote: string;
}

interface Props {
  heading: string;
  blocks: CTABlock[];
  closing: string;
  contact: string;
}

const { heading, blocks, closing, contact } = Astro.props;
---

<section class="audience-cta">
  <div class="container-es">
    <h2 class="cta-heading">{heading}</h2>

    <div class="cta-grid">
      {blocks.map(b => (
        <div class="cta-block">
          <span class="cta-audience">{b.audience}</span>
          <p class="cta-copy">{b.copy}</p>
          <div class="cta-actions">
            <a href={b.cta.href} class="cta-btn" target="_blank" rel="noopener noreferrer">
              {b.cta.label}
            </a>
            <p class="cta-risk">{b.riskNote}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="cta-footer">
      <hr class="cta-rule" />
      <p class="closing-line">{closing}</p>
      <p class="contact-line">{contact}</p>
    </div>
  </div>
</section>

<style>
  .audience-cta {
    padding-top: var(--section-pad-y);
    padding-bottom: var(--section-pad-y);
    background-color: var(--color-forest);
  }

  .cta-heading {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.875rem, 4vw, 3.25rem);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.016em;
    color: var(--color-canvas);
    margin-bottom: 3rem;
  }

  /* ── Grid ── */
  .cta-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background-color: rgba(234, 245, 236, 0.15); /* hairline between columns */
  }
  @media (min-width: 768px) {
    .cta-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .cta-block {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2rem;
    background-color: var(--color-forest);
  }

  .cta-audience {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .cta-copy {
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(234, 245, 236, 0.85);
    flex: 1;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cta-btn {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-forest);
    background-color: var(--color-canvas);
    text-decoration: none;
    padding: 0.75rem 1.375rem;
    border-radius: var(--radius);
    transition: background-color 180ms ease;
    align-self: flex-start;
  }
  .cta-btn:hover { background-color: var(--color-card); }

  .cta-risk {
    font-size: 0.75rem;
    color: rgba(234, 245, 236, 0.55);
  }

  /* ── Footer ── */
  .cta-footer {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cta-rule {
    border: none;
    border-top: 1px solid rgba(234, 245, 236, 0.2);
    margin-bottom: 0.5rem;
  }

  .closing-line {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-canvas);
    opacity: 0.9;
  }

  .contact-line {
    font-size: 0.75rem;
    color: rgba(234, 245, 236, 0.6);
  }
</style>
