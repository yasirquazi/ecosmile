---
interface Props {
  headline: string;
  sub: string;
  cta: { label: string; href: string };
  riskNote: string;
  trustBar: string;
}

const { headline, sub, cta, riskNote, trustBar } = Astro.props;
---

<section class="hero">
  <div class="container-es">

    <h1 class="hero-headline">{headline}</h1>

    <div class="hero-bottom">
      <p class="hero-sub">{sub}</p>
      <div class="hero-actions">
        <a href={cta.href} class="hero-cta" target="_blank" rel="noopener noreferrer">
          {cta.label}
        </a>
        <p class="risk-note">{riskNote}</p>
      </div>
    </div>

    <div class="trust-bar">
      <p class="trust-text">{trustBar}</p>
    </div>

  </div>
</section>

<style>
  .hero {
    background-color: var(--color-forest);
    padding-top: var(--section-pad-y);
    padding-bottom: var(--section-pad-y);
  }

  .hero-headline {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-canvas);
    font-variation-settings: 'opsz' 80;
    margin-bottom: clamp(4rem, 10vw, 7rem);
  }

  .hero-bottom {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 640px;
  }

  .hero-sub {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-rule-soft);
    max-width: 52ch;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .hero-cta {
    display: inline-block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-forest);
    background-color: var(--color-canvas);
    text-decoration: none;
    padding: 1rem 2rem;
    border-radius: var(--radius-pill);
    transition: background-color 180ms ease;
  }
  .hero-cta:hover { background-color: var(--color-card); }

  .risk-note {
    font-size: 0.75rem;
    color: var(--color-rule);
    letter-spacing: 0.01em;
  }

  .trust-bar {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-mid);
  }

  .trust-text {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-canvas);
  }
</style>
