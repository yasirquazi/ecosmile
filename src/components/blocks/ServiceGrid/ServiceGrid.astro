---
interface Service {
  title: string;
  body: string;
  audience: string[];
  imageSrc?: string;  // if provided, shown instead of the colour block
}

interface Props {
  eyebrow?: string;
  heading: string;
  services: Service[];
}

const { eyebrow, heading, services } = Astro.props;
---

<section class="services">
  <div class="container-es">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h2 class="services-heading">{heading}</h2>
    <div class="services-grid">
      {services.map(s => (
        <article class="service-card">
          <div class="card-color-wrapper">
            {s.imageSrc
              ? <img src={s.imageSrc} alt={s.title} class="card-img" />
              : <div class="card-color-block" aria-hidden="true"></div>
            }
          </div>
          <div class="card-content">
            <h3 class="card-title">{s.title}</h3>
            <p class="card-body">{s.body}</p>
          </div>
          <div class="card-footer">
            <span class="for-label">For</span>
            <div class="audience-pills">
              {s.audience.map(a => <span class="audience-pill">{a}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding-top: var(--section-pad-y);
    padding-bottom: var(--section-pad-y);
    background-color: var(--color-canvas);
  }

  .services-heading {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.875rem, 4vw, 3.25rem);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.016em;
    color: var(--color-ink);
    margin-bottom: 3rem;
  }

  /* ── Grid: 1 col → 2×2 ── */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Card ── */
  .service-card {
    background-color: var(--color-surface);
    border: 1px solid color-mix(in srgb, var(--color-ink) 15%, transparent);
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    min-height: 420px;
  }

  /* ── Inset colour block — p-2 wrapper + rounded inner block ── */
  .card-color-wrapper {
    padding: 0.5rem;
    flex: 1;
  }
  .card-color-block {
    width: 100%;
    height: 100%;
    min-height: 180px; /* mobile floor */
    border-radius: 20px;
  }
  @media (min-width: 640px) {
    .card-color-block { min-height: 280px; } /* desktop floor */
  }
  .card-img {
    width: 100%;
    height: 100%;
    min-height: 180px;
    border-radius: 20px;
    object-fit: cover;
    display: block;
  }
  @media (min-width: 640px) {
    .card-img { min-height: 280px; }
  }

  .service-card:nth-child(1) .card-color-block { background-color: var(--color-forest); }
  .service-card:nth-child(2) .card-color-block { background-color: var(--color-mid); }
  .service-card:nth-child(3) .card-color-block { background-color: var(--color-earth); }
  .service-card:nth-child(4) .card-color-block { background-color: var(--color-gold); }

  /* ── Text block ── */
  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem;
  }

  .card-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.2;
  }

  .card-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink-soft);
  }

  /* ── Footer: For + pills ── */
  .card-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem;
  }

  .for-label {
    font-size: 1rem;
    color: var(--color-ink-soft);
    flex-shrink: 0;
  }

  .audience-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .audience-pill {
    font-size: 0.75rem;
    color: #fff;
    background-color: var(--color-mid);
    border-radius: var(--radius-pill);
    padding: 0.25rem 0.5rem;
    line-height: 1.4;
    white-space: nowrap;
  }
</style>
