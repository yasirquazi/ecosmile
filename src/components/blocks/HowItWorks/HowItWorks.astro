---
interface Step {
  number: string;
  title: string;
  body: string;
}

interface Props {
  eyebrow?: string;
  heading: string;
  steps: Step[];
  cta: { label: string; href: string };
  riskNote: string;
}

const { eyebrow, heading, steps, cta, riskNote } = Astro.props;
---

<section class="hiw">
  <div class="container-es">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h2 class="hiw-heading">{heading}</h2>

    <div class="steps-list">
      {steps.map(step => (
        <div class="step">
          <span class="step-number">{step.number}</span>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-body">{step.body}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="hiw-cta">
      <a href={cta.href} class="btn-primary" target="_blank" rel="noopener noreferrer">
        {cta.label}
      </a>
      <p class="risk-note">{riskNote}</p>
    </div>
  </div>
</section>

<style>
  .hiw {
    padding-top: var(--section-pad-y);
    padding-bottom: var(--section-pad-y);
    background-color: var(--color-gold);
  }

  .hiw-heading {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.875rem, 4vw, 3.25rem);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.016em;
    color: #fff;
    margin-bottom: 3rem;
  }

  /* ── Steps — vertical stacked list ── */
  .steps-list {
    display: flex;
    flex-direction: column;
  }

  .step {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 0 3rem;
    align-items: start;
    padding: 2rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.25);
  }

  .step:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
  }

  .step-number {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 5rem;
    font-weight: 300;
    line-height: 1;
    color: rgba(255, 255, 255, 0.45);
    font-variation-settings: 'opsz' 72;
  }

  .step-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.75rem;
  }

  .step-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
  }

  .step-body {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
  }

  /* ── CTA ── */
  .hiw-cta {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .btn-primary {
    display: inline-block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-gold);
    background-color: #fff;
    text-decoration: none;
    padding: 1rem 2rem;
    border-radius: var(--radius-pill);
    transition: opacity 180ms ease;
  }
  .btn-primary:hover { opacity: 0.9; }

  .risk-note {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.65);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .step {
      grid-template-columns: 4rem 1fr;
      gap: 0 1.5rem;
    }

    .step-number { font-size: 3rem; }
  }
</style>
