---
import '@/styles/globals.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Eco Smile picks up your unused items and gets them to Bangalore families who need them. Free pickup. No forms. WhatsApp us today.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>

    <!-- Floating pill navigation -->
    <header class="site-header">
      <nav class="nav-inner">

        <a href="/" class="wordmark" aria-label="Eco Smile — Home">
          <svg width="120" height="28" viewBox="0 0 120 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <text x="0" y="21" font-family="Fraunces, Georgia, serif" font-size="20" font-weight="500" fill="currentColor">Eco Smile</text>
          </svg>
        </a>

        <ul class="nav-links" role="list">
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>

        <a href="https://wa.me/918123679864" target="_blank" rel="noopener noreferrer" class="btn-nav">
          WhatsApp Us
        </a>

        <!-- Hamburger — mobile only -->
        <button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg width="20" height="16" viewBox="0 0 20 16" fill="none" aria-hidden="true">
            <rect width="20" height="2" rx="1" fill="currentColor"/>
            <rect y="7" width="20" height="2" rx="1" fill="currentColor"/>
            <rect y="14" width="20" height="2" rx="1" fill="currentColor"/>
          </svg>
        </button>

      </nav>
    </header>

    <!-- Mobile full-screen menu -->
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <button class="mobile-menu-close" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M2 2L18 18M18 2L2 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <nav class="mobile-menu-nav">
        <ul role="list">
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
        <a href="https://wa.me/918123679864" target="_blank" rel="noopener noreferrer" class="mobile-cta">
          WhatsApp Us
        </a>
      </nav>
    </div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="container-es">
        <hr class="section-rule" />
        <div class="footer-inner">
          <div class="footer-brand">
            <span class="wordmark-text">Eco Smile</span>
            <p class="footer-tagline">What could be excess to you is essential to someone.</p>
          </div>
          <div class="footer-links">
            <a href="/">Home</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
          </div>
          <div class="footer-contact">
            <p>+91 81236 79864</p>
            <p>WhatsApp available · Bangalore</p>
            <p class="footer-partner">In partnership with <strong>Project Smile Trust</strong></p>
          </div>
        </div>
        <div class="footer-base">
          <p>&copy; {new Date().getFullYear()} Eco Smile. Bangalore, India.</p>
        </div>
      </div>
    </footer>

  </body>
</html>

<script is:inline>
  (function () {
    const hamburger = document.querySelector('.hamburger');
    const menu      = document.getElementById('mobile-menu');
    const closeBtn  = document.querySelector('.mobile-menu-close');
    const links     = menu.querySelectorAll('a');

    function openMenu() {
      menu.classList.add('is-open');
      menu.setAttribute('aria-hidden', 'false');
      hamburger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      menu.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    hamburger.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    links.forEach(function (link) { link.addEventListener('click', closeMenu); });
  })();
</script>

<style>
  /* ── Floating pill nav ── */
  .site-header {
    position: fixed;
    top: 1.25rem;
    left: 0;
    right: 0;
    z-index: 50;
    max-width: 760px;
    margin: 0 auto;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in srgb, var(--color-ink) 15%, transparent);
    background-color: color-mix(in srgb, var(--color-canvas) 90%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 16px rgba(10, 20, 10, 0.08);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.375rem 0.5rem;
    gap: 1rem;
  }

  .wordmark {
    text-decoration: none;
    color: var(--color-forest);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    padding: 0.25rem 0.5rem;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0.25rem;
  }

  .nav-links a {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-pill);
    transition: background-color 150ms ease, color 150ms ease;
  }

  .nav-links a:hover {
    background-color: var(--color-rule);
    color: var(--color-forest);
  }

  .btn-nav {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-canvas);
    background-color: var(--color-forest);
    text-decoration: none;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-pill);
    white-space: nowrap;
    transition: background-color 150ms ease;
    flex-shrink: 0;
  }

  .btn-nav:hover { background-color: var(--color-mid); }

  /* ── Hamburger — hidden on desktop ── */
  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-ink);
    padding: 0.5rem;
    flex-shrink: 0;
  }

  /* ── Mobile overrides ── */
  @media (max-width: 640px) {
    .site-header {
      left: 1rem;
      right: 1rem;
      max-width: none;
    }

    .nav-links,
    .btn-nav    { display: none; }
    .hamburger  { display: flex; align-items: center; justify-content: center; }
  }

  /* ── Mobile full-screen menu ── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 99;
    background-color: var(--color-canvas);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-menu-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-ink);
    padding: 0.5rem;
  }

  .mobile-menu-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mobile-menu-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .mobile-menu-nav ul a {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .mobile-menu-nav ul a:hover { color: var(--color-forest); }

  .mobile-cta {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-canvas);
    background-color: var(--color-forest);
    text-decoration: none;
    padding: 0.75rem 2rem;
    border-radius: var(--radius-pill);
    transition: background-color 150ms ease;
  }

  .mobile-cta:hover { background-color: var(--color-mid); }

  /* ── Footer ── */
  .site-footer {
    margin-top: 4rem;
    padding-bottom: 2rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 3rem;
    padding: 3rem 0 2rem;
  }

  .wordmark-text {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-forest);
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    font-size: 0.75rem;
    color: var(--color-ink-soft);
    line-height: 1.5;
    max-width: 28ch;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    font-size: 0.75rem;
    color: var(--color-ink-soft);
    text-decoration: none;
    transition: color 180ms ease;
  }

  .footer-links a:hover { color: var(--color-forest); }

  .footer-contact p {
    font-size: 0.75rem;
    color: var(--color-ink-soft);
    line-height: 1.8;
  }

  .footer-partner strong { color: var(--color-forest); }

  .footer-base {
    border-top: 1px solid var(--color-rule-soft);
    padding-top: 1.5rem;
  }

  .footer-base p {
    font-size: 0.75rem;
    color: var(--color-ink-soft);
  }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
